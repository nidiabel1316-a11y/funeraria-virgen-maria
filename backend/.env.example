# Neon: copia la cadena de conexión desde https://console.neon.tech (incluye ?sslmode=require)
DATABASE_URL=postgresql://usuario:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Secreto largo y aleatorio para firmar JWT (mín. 32 caracteres)
JWT_SECRET=cambia_esto_por_un_string_largo_y_secreto_minimo_32_chars

# Orígenes permitidos CORS (separados por coma). Producción + local:
CORS_ORIGIN=https://funerariavirgenmaria.com,http://localhost:5500,http://127.0.0.1:5500

PORT=3001

# URL pública del sitio (index.html) para enlaces de "olvidé contraseña"
APP_PUBLIC_URL=https://funerariavirgenmaria.com

# Correo (recuperación de contraseña). Sin SMTP, el enlace solo se registra en consola.
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@tudominio.com
# SMTP_PASS=tu_clave
# SMTP_FROM="Funeraria VM <noreply@tudominio.com>"

# Panel admin API (/api/admin/*) — cámbialos en producción
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
