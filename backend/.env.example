# =============================================================================
# Funeraria Virgen María — API. Copia a .env y rellena (cp .env.example .env).
# =============================================================================

# --- Base de datos (Neon) ---
DATABASE_URL=postgresql://usuario:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- JWT: mínimo 32 caracteres; sin espacios dentro del valor ---
JWT_SECRET=cambia_esto_por_un_string_largo_y_secreto_minimo_32_chars

# --- Servidor ---
PORT=3001
NODE_ENV=development

# --- CORS (coma). Producción + herramientas locales comunes ---
CORS_ORIGIN=https://funerariavirgenmaria.com,https://www.funerariavirgenmaria.com,http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# --- URL pública del sitio (enlaces de “olvidé contraseña”) ---
APP_PUBLIC_URL=https://funerariavirgenmaria.com

# --- Panel admin (/api/admin/login): dueño (owner) ---
ADMIN_USER=admin
ADMIN_PASSWORD=cambia_esta_clave_por_una_larga_y_segura

# --- Secretaría solo por .env (opcional): ambas líneas o ninguna. El backend acepta también DMIN_SECRETARY_PASSWORD y ADMIN_SECRETARY_PASSWOR (typo sin la D final). ---
# ADMIN_SECRETARY_USER=secretaria_vm
# ADMIN_SECRETARY_PASSWORD=otra_clave_segura_distinta

# --- Correo (opcional) ---
# SMTP_HOST=smtp.hostinger.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=noreply@tudominio.com
# SMTP_PASS=tu_clave
# SMTP_FROM=Funeraria VM <noreply@tudominio.com>
